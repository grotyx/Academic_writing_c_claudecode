# OS generated files
.DS_Store

# Local settings
.claude/settings.local.json
.vscode/

# Presentation files (not part of manuscript workflow)
presentation/

# Personal profile (author info, contacts, funding)
profile/

# Own papers (private — published paper summaries with personal research context)
# Exception: example file stays in repo as a template reference
knowledge/own_papers/*.md
!knowledge/own_papers/example_*.md
knowledge/own_papers/*.pdf

# Reference PDFs — copyright-protected, do not commit
knowledge/pdf/

# Style anchor PDFs — copyright-protected, local only
Style/PDF/**/*.pdf
Style/PDF/**/*.PDF

# Style anchor markdown files may contain private/local analysis context
Style/own/*.md
!Style/own/example_*.md
Style/landmark/*.md
Style/target_journal/*.md
!Style/style_guide.md
!Style/terminology.md
